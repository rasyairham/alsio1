{
  "version": 2,
  "buildCommand": "npm install --prefix frontend --include=dev && cd frontend && node node_modules/vite/bin/vite.js build",
  "outputDirectory": "frontend/dist",
  "installCommand": "npm install --prefix backend",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
